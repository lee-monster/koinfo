{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "travel.koinfo.kr" }],
      "destination": "/travel-index.html"
    },
    {
      "source": "/((?!api|js|css|sites|images|favicon).*)",
      "has": [{ "type": "host", "value": "travel.koinfo.kr" }],
      "destination": "/travel-index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=60, stale-while-revalidate=300" }
      ]
    }
  ]
}
